# ─────────────────────────────────────────────────────────
# Interro-Claw — Environment Variables
# Copy to .env and fill in your values.
# Or place at ~/.interro-claw/.env for global config.
#
# Precedence: session env > global env > CWD/.env > ~/.interro-claw/.env > interactive prompt
# ─────────────────────────────────────────────────────────

# LLM provider: "openai" | "claude" | "nvidia" | "ollama" | "groq"
LLM_PROVIDER=openai
# Groq (free tier)
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_LIGHT=gpt-4o-mini

# Claude (Anthropic)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MODEL_HEAVY=claude-opus-4-20250514

# NVIDIA NIM (free tier)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Ollama (local — no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Orchestrator
MAX_CONCURRENT_AGENTS=2
RATE_LIMIT_RPM=20
LOG_LEVEL=INFO

# Sentry (optional — leave blank to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
CACHE_TTL_SECONDS=3600

# Streaming
ENABLE_STREAMING=0

# Self-reflection
MAX_REFLECTION_DEPTH=3
ENABLE_REFLECTION=1

# Skills
SKILLS_DIR=skills

# Guardrails
MAX_TOKENS_PER_CALL=4096
MAX_LLM_CALLS_PER_SESSION=200
MAX_OUTPUT_CHARS=50000
MAX_AGENT_RUNTIME_SECONDS=300

# Project
DEFAULT_PROJECT_ID=default
